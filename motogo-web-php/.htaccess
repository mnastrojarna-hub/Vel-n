RewriteEngine On
RewriteBase /

# ---- SEO: www -> non-www + HTTPS ----
# DŮLEŽITÉ: motogo24.com (nová verze) a motogo24.cz (stará funkční verze)
# se VĚDOMĚ NEPROPOJUJÍ křížově — zatím běží každá samostatně. Až se spojí,
# přidá se sem redirect mezi doménami.

# 1) www -> non-www (každá doména zůstává na sobě samé), zároveň vynutí HTTPS
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L,NE]

# 2) http -> https (pokud HTTPS není aktivní). Bereme v úvahu i reverse proxy
#    (Cloudflare, load balancer) přes X-Forwarded-Proto a SERVER_PORT.
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !=https
RewriteCond %{HTTP:CF-Visitor} !{"scheme":"https"} [NC]
RewriteCond %{SERVER_PORT} !^443$
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L,NE]

# ---- Hezké URL: všechno, co není soubor/složka, jde přes index.php ----
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]

# Bezpečný default error handling — nepropagovat PHP interní chyby do
# browseru, ale logovat je server-side.
php_flag display_errors off
php_flag log_errors on

# Komprese + cache headers pro statické assety
<IfModule mod_brotli.c>
    AddOutputFilterByType BROTLI_COMPRESS text/html text/css text/plain text/xml text/markdown application/javascript application/json application/xml application/xhtml+xml application/rss+xml application/ld+json image/svg+xml font/ttf font/otf font/woff font/woff2
</IfModule>
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml text/markdown application/javascript application/json application/xml application/xhtml+xml application/rss+xml application/ld+json image/svg+xml
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/svg+xml "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/webp "access plus 30 days"
    ExpiresByType image/avif "access plus 30 days"
    ExpiresByType image/x-icon "access plus 30 days"
    ExpiresByType text/css "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
    ExpiresByType application/manifest+json "access plus 7 days"
    ExpiresByType application/rss+xml "access plus 1 hour"
    ExpiresByType text/markdown "access plus 1 hour"
    ExpiresByType application/ld+json "access plus 1 hour"
    ExpiresByType font/woff2 "access plus 30 days"
    ExpiresByType font/woff "access plus 30 days"
</IfModule>

# Security + SEO HTTP headers — důležité jak pro skenování webu (Mozilla Observatory,
# Lighthouse), tak pro důvěryhodnost pro Google/Seznam/AI crawlery. Hodnoty jsou
# konzervativní (povolíme inline scripty pro existující JS, Stripe iframe, Supabase).
<IfModule mod_headers.c>
    # HSTS — vynutí HTTPS na 2 roky (zveřejni do preload listu po ověření)
    Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains"
    # Upgrade-Insecure-Requests — donutí prohlížeč přepsat http:// odkazy
    # ve vlastních stránkách na https:// (pomáhá při embed iframe, mixed content).
    Header always set Content-Security-Policy "upgrade-insecure-requests"
    # Anti-MIME sniffing
    Header always set X-Content-Type-Options "nosniff"
    # Pouze same-origin frame embedding (anti-clickjacking)
    Header always set X-Frame-Options "SAMEORIGIN"
    # Referrer policy — minimální únik dat při kliknutí na externí odkaz
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    # Permissions-Policy — vypnutí zbytečných API (kamera, mikrofon, USB, ...)
    Header always set Permissions-Policy "accelerometer=(), camera=(), geolocation=(self), gyroscope=(), magnetometer=(), microphone=(), payment=(self \"https://js.stripe.com\"), usb=(), interest-cohort=()"
    # Cross-Origin-Opener-Policy — izolace okna pro Stripe Checkout flow
    Header always set Cross-Origin-Opener-Policy "same-origin-allow-popups"
    # Robot directiva i přes HTTP headers (zachytí PDF a další non-HTML)
    Header set X-Robots-Tag "index, follow, max-image-preview:large, max-snippet:-1"
    # CORS pro veřejné AI/SEO soubory — agent.json, llms.txt, sitemap, openapi
    <FilesMatch "(agent\.json|ai-plugin\.json|openapi\.(yaml|json)|llms.*\.txt|ai\.txt|robots\.txt|sitemap\.xml|feed\.xml|manifest\.webmanifest)$">
        Header set Access-Control-Allow-Origin "*"
        Header set Access-Control-Allow-Methods "GET, OPTIONS"
        Header set X-Robots-Tag "noindex, follow"
    </FilesMatch>
    # Long-term immutable cache pro hashované assety (CSS/JS s versionem)
    <FilesMatch "\.(woff2?|ttf|otf|svg)$">
        Header set Cache-Control "public, max-age=2592000, immutable"
    </FilesMatch>
    # Krátká cache HTML — chceme ať Google vidí čerstvé verze
    <FilesMatch "\.(html|php)$">
        Header set Cache-Control "public, max-age=300, must-revalidate"
    </FilesMatch>
    # Preconnect na Supabase + fonts přes Link header (HTTP/2 push hint).
    # Browser umí preconnect už při prvním HTML byte, dřív než přečte <head>.
    Header add Link "<https://fonts.googleapis.com>; rel=preconnect"
    Header add Link "<https://fonts.gstatic.com>; rel=preconnect; crossorigin"
    Header add Link "<https://vnwnqteskbykeucanlhk.supabase.co>; rel=preconnect; crossorigin"
</IfModule>

# Správný MIME pro nové formáty
<IfModule mod_mime.c>
    AddType application/manifest+json .webmanifest
    AddType application/ld+json .jsonld
    AddType text/markdown .md
    AddType image/avif .avif
    AddType image/webp .webp
    AddType font/woff2 .woff2
</IfModule>
