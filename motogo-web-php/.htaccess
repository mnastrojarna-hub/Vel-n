RewriteEngine On
RewriteBase /

# ---- SEO: www -> non-www + HTTPS ----
# DŮLEŽITÉ: motogo24.com (nová verze) a motogo24.cz (stará funkční verze)
# se VĚDOMĚ NEPROPOJUJÍ křížově — každá doména běží samostatně.
#
# SSL certifikát: motogo24.cz má platný cert, motogo24.com zatím NE
# (dokud se cert nevystaví, NESMÍME na ni nutit HTTPS — browser jinak
# hlásí ERR_CERT_COMMON_NAME_INVALID). Až cert pro .com dorazí, odstraň
# podmínku "!motogo24\.com" z pravidla 1 a 2.

# 1) www -> non-www (schéma podle toho, zda doména má cert)
#    motogo24.cz: www -> https://non-www
RewriteCond %{HTTP_HOST} ^www\.motogo24\.cz$ [NC]
RewriteRule ^(.*)$ https://motogo24.cz/$1 [R=301,L]
#    motogo24.com (bez certu): www -> http://non-www
RewriteCond %{HTTP_HOST} ^www\.motogo24\.com$ [NC]
RewriteRule ^(.*)$ http://motogo24.com/$1 [R=301,L]

# 2) http -> https POUZE na doménách s platným certem (tj. motogo24.cz).
#    motogo24.com zatím HTTPS nenutíme — chybí cert.
RewriteCond %{HTTP_HOST} ^motogo24\.cz$ [NC]
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !=https
RewriteRule ^(.*)$ https://motogo24.cz/$1 [R=301,L]

# ---- Hezké URL: všechno, co není soubor/složka, jde přes index.php ----
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]

# Bezpečný default error handling — nepropagovat PHP interní chyby do
# browseru, ale logovat je server-side.
php_flag display_errors off
php_flag log_errors on

# Komprese + cache headers pro statické assety
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json text/xml application/xml image/svg+xml
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/svg+xml "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/webp "access plus 30 days"
    ExpiresByType text/css "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
</IfModule>
