<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ splash screen configuration -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowSplashScreenBackground">@android:color/black</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_logo</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@android:color/black</item>
    </style>
    <!-- Must extend MaterialComponents for Stripe Payment Sheet to work. -->
    <style name="NormalTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
    </style>
</resources>
