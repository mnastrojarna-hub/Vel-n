<?xml version='1.0' encoding='utf-8'?>
<widget id="cz.motogo24.app" version="5.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0" xmlns:android="http://schemas.android.com/apk/res/android">
    <name>MotoGo24</name>
    <description>MotoGo24 – Půjčovna motorek</description>
    <author email="info@motogo24.cz" href="https://motogo24.cz">MotoGo24</author>

    <content src="index.html" />

    <preference name="Scheme" value="https" />
    <preference name="hostname" value="localhost" />
    <preference name="DisallowOverscroll" value="true" />
    <preference name="Orientation" value="portrait" />
    <preference name="BackgroundColor" value="#000000" />
    <preference name="StatusBarBackgroundColor" value="#000000" />
    <preference name="StatusBarStyle" value="lightcontent" />
    <preference name="AndroidWindowSplashScreenAnimatedIcon" value="www/res/icon/android/icon-192.png" />
    <preference name="AndroidWindowSplashScreenBackground" value="#000000" />

    <platform name="android">
        <preference name="android-minSdkVersion" value="24" />
        <preference name="android-compileSdkVersion" value="34" />
        <preference name="android-targetSdkVersion" value="34" />
        <preference name="AndroidLaunchMode" value="singleTask" />
        <preference name="GradlePluginGoogleServicesEnabled" value="false" />

        <edit-config file="app/src/main/AndroidManifest.xml" mode="merge" target="/manifest/application">
            <application android:usesCleartextTraffic="true" />
        </edit-config>

        <icon density="ldpi" src="www/res/icon/android/icon-192.png" />
        <icon density="mdpi" src="www/res/icon/android/icon-192.png" />
        <icon density="hdpi" src="www/res/icon/android/icon-192.png" />
        <icon density="xhdpi" src="www/res/icon/android/icon-512.png" />
        <icon density="xxhdpi" src="www/res/icon/android/icon-512.png" />
        <icon density="xxxhdpi" src="www/res/icon/android/icon-512.png" />

        <config-file parent="/*" target="AndroidManifest.xml">
            <uses-permission android:name="android.permission.CAMERA" />
            <uses-permission android:name="android.permission.RECORD_AUDIO" />
            <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
        </config-file>
        <config-file parent="/*" target="AndroidManifest.xml">
            <uses-feature android:name="android.hardware.camera" android:required="false" />
            <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />
        </config-file>
    </platform>

    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />
    <allow-navigation href="https://*.supabase.co/*" />
    <allow-navigation href="https://*.supabase.in/*" />
    <allow-navigation href="https://cdn.jsdelivr.net/*" />
    <allow-navigation href="https://fonts.googleapis.com/*" />
    <allow-navigation href="https://fonts.gstatic.com/*" />

    <plugin name="cordova-plugin-camera" spec="^7.0.0" />
    <plugin name="cordova-plugin-android-permissions" spec="^1.1.5" />
    <plugin name="cordova-plugin-geolocation" spec="^5.0.0" />
    <plugin name="cordova-plugin-statusbar" spec="^4.0.0" />
    <plugin name="cordova-plugin-vibration" spec="^3.1.1" />
    <plugin name="cordova-plugin-fingerprint-aio" spec="^6.0.0" />
    <plugin name="cordova-plugin-inappbrowser" spec="^6.0.0" />
    <plugin name="cordova-plugin-file" spec="^8.1.2" />
    <plugin name="cordova-plugin-local-notification-12" spec="^0.0.3" />

    <engine name="android" spec="^13.0.0" />
</widget>
